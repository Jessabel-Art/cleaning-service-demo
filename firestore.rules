rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------- Helpers ---------- */

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmailLower() {
      return (isSignedIn() && request.auth.token.email != null)
        ? lower(request.auth.token.email)
        : "";
    }

    // Whitelisted admin emails
    function isWhitelistedEmail() {
      let e = userEmailLower();
      return e in [
        "jessabel.santos@gmail.com",
        "sanchezservices24@yahoo.com"
      ];
    }

    // Whitelisted admin UIDs
    function isWhitelistedUid() {
      return isSignedIn() &&
        request.auth.uid in [
          "1Ku2G5K7EnMBOT5tHCleuL0tDPz1",
          "tcNfLl71F4egLReiutPzYvQaNvl2"
        ];
    }

    // Optional: /admins/{uid} doc
    function isAdminsDocListed() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Optional: profiles/{uid}.role = admin|owner
    function isProfileAdminOrOwner() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role
               in ["admin", "owner"];
    }

    // Main admin gate
    function isAdmin() {
      return isWhitelistedUid()
          || isWhitelistedEmail()
          || isAdminsDocListed()
          || isProfileAdminOrOwner();
    }

    // Key helpers
    function hasKey(keys) {
      return isSignedIn() &&
             keys is list &&
             (('uid:' + request.auth.uid) in keys ||
              ('email:' + userEmailLower()) in keys);
    }

    function canAccessByDocKeys(docData) {
      return (
        ('ownerKeys' in docData && hasKey(docData.ownerKeys)) ||
        ('adminKeys' in docData && hasKey(docData.adminKeys))
      );
    }

    /* ---------- Admins ---------- */

    match /admins/{uid} {
      allow read, write: if isAdmin();
    }

    /* ---------- Profiles ---------- */

    match /profiles/{uid} {
      allow read, write: if isAdmin() ||
        (isSignedIn() && request.auth.uid == uid);
    }

    /* ---------- Top-Level Addresses ---------- */

    match /addresses/{id} {
      allow create: if isSignedIn() &&
                    ("userId" in request.resource.data) &&
                    request.resource.data.userId == request.auth.uid;

      allow read, update, delete: if
        isAdmin() ||
        (isSignedIn() &&
         ("userId" in resource.data) &&
         resource.data.userId == request.auth.uid) ||
        (isSignedIn() && canAccessByDocKeys(resource.data));
    }

    /* ---------- Bookings ---------- */

    function safeClientBookingUpdate() {
      let old = resource.data;
      let neu = request.resource.data;

      // Critical fields that clients CANNOT change
      let unchangedCritical =
           neu.totalPrice == old.totalPrice &&
           neu.cost == old.cost &&
           neu.serviceName == old.serviceName &&
           neu.userId == old.userId &&
           neu.ownerKeys == old.ownerKeys &&
           neu.adminKeys == old.adminKeys;

      // Status: allow pending -> cancelled; otherwise must stay the same
      let oldStatus = (old.status == null) ? "pending" : old.status;
      let newStatus = (neu.status == null) ? oldStatus : neu.status;
      let statusOk =
        newStatus == oldStatus ||
        (oldStatus == "pending" && newStatus == "cancelled");

      let oldKeys = old.keys();
      let newKeys = neu.keys();

      // Allowed mutable fields for client updates
      let allowedMutableFields = [
        'scheduledAt', 'startAt', 'endAt', 'dateKey', 'timeLabel',
        'updatedAt', 'notes', 'cleanerNotes', 'accessNotes'
      ];

      // Ensure no keys changed besides allowed mutable ones
      let keysUnchanged = oldKeys.hasAll(newKeys.removeAll(allowedMutableFields)) &&
                          newKeys.hasAll(oldKeys.removeAll(allowedMutableFields));

      return unchangedCritical && statusOk && keysUnchanged;
    }

    match /bookings/{id} {

      function isBookingOwner() {
        return isSignedIn() &&
          (
            ("userId" in resource.data && resource.data.userId == request.auth.uid) ||
            ("ownerKeys" in resource.data &&
             (("uid:" + request.auth.uid) in resource.data.ownerKeys ||
              (request.auth.token.email != null &&
               ("email:" + lower(request.auth.token.email)) in resource.data.ownerKeys)))
          );
      }

      // ⭐ Any signed-in user can create a booking (fixes your bug)
      allow create: if isSignedIn();

      // READ rules
      allow read: if
        isAdmin() ||
        (
          isSignedIn() &&
          (
            ("userId" in resource.data &&
             resource.data.userId == request.auth.uid) ||

            ("contact" in resource.data &&
             "emailLower" in resource.data.contact &&
             resource.data.contact.emailLower == userEmailLower()) ||

            canAccessByDocKeys(resource.data)
          )
        );

      // UPDATE / DELETE rules
      allow update, delete: if
        isAdmin() ||
        (
          isBookingOwner() &&
          safeClientBookingUpdate()
        );
    }

    /* ---------- Services ---------- */

    match /services/{slug} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /* ---------- Mail ---------- */

    match /mail/{id} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }

    /* ---------- Reports ---------- */

    match /reports/{id} {
      allow read, write: if
        isAdmin() ||
        (isSignedIn() && canAccessByDocKeys(resource.data));
    }

    /* ---------- Users & addresses ---------- */

    match /users/{uid} {
      allow read, update: if
        isSignedIn() &&
        (request.auth.uid == uid || isAdmin());

      match /addresses/{addrId} {
        allow create: if isSignedIn() && request.auth.uid == uid;
        allow read, update, delete: if
          isSignedIn() &&
          (request.auth.uid == uid || isAdmin());
      }
    }

    /* ---------- Reviews ---------- */

    match /reviews/{id} {
      allow read: if resource.data.status == "approved" || isAdmin();

      allow create: if isSignedIn() &&
        request.resource.data.status == "pending" &&
        request.resource.data.clientId == request.auth.uid &&
        ("displayName" in request.resource.data) &&
        request.resource.data.displayMode in ["anonymous", "initials", "firstInitialLastName"];

      allow update, delete: if isAdmin();
    }

    /* ---------- Availability ---------- */

    match /availability/{dateKey} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /* ---------- Global Admin Override ---------- */

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
