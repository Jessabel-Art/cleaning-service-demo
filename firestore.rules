rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------- Helpers ---------- */
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmailLower() {
      return (isSignedIn() && request.auth.token.email != null)
        ? lower(request.auth.token.email)
        : "";
    }

    // Allow-list by email (include dotless Gmail variant to avoid alias issues)
    function isWhitelistedEmail() {
      let e = userEmailLower();
      return e in [
        "jessabel.santos@gmail.com",
        "jessabelsantos@gmail.com",
        "sanchezservices24@yahoo.com"
      ];
    }

    // Allow-list by UID (the two you showed in /admins)
    function isWhitelistedUid() {
      return isSignedIn() && request.auth.uid in [
        "1Ku2G5K7EnMBOT5tHCleuL0tDPz1",
        "tcNfL171F4eglLReiutPzYvQaNv12"
      ];
    }

    // Optional: /admins/{uid} document gate
    function isAdminsDocListed() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Optional: profiles/{uid}.role ∈ {"admin","owner"}
    function isProfileAdminOrOwner() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role
               in ["admin", "owner"];
    }

    // Main admin gate — any of the above qualifies
    function isAdmin() {
      return isWhitelistedUid() || isWhitelistedEmail() || isAdminsDocListed() || isProfileAdminOrOwner();
    }

    // owner/admin keys helper
    function hasKey(keys) {
      return isSignedIn() &&
             keys is list &&
             (('uid:' + request.auth.uid) in keys ||
              ('email:' + userEmailLower()) in keys);
    }

    function canAccessByDocKeys(docData) {
      return (('ownerKeys' in docData && hasKey(docData.ownerKeys)) ||
              ('adminKeys' in docData && hasKey(docData.adminKeys)));
    }

    /* ---------- Admins collection (manage via admin UI if needed) ---------- */
    match /admins/{uid} {
      allow read, write: if isAdmin();
    }

    /* ---------- Profiles ---------- */
    match /profiles/{uid} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    /* ---------- Top-level Addresses (if you use this) ---------- */
    match /addresses/{id} {
      allow create: if isSignedIn() &&
                    ("userId" in request.resource.data) &&
                    request.resource.data.userId == request.auth.uid;

      allow read, update, delete: if isAdmin() ||
        (isSignedIn() && ("userId" in resource.data) && resource.data.userId == request.auth.uid) ||
        (isSignedIn() && canAccessByDocKeys(resource.data));
    }

    /* ---------- Bookings ---------- */
    match /bookings/{id} {
      allow create: if isAdmin() ||
        (isSignedIn() &&
         ("userId" in request.resource.data) &&
         request.resource.data.userId == request.auth.uid) ||
        (request.resource.data.createdVia == "admin_manual") ||
        (isSignedIn() && canAccessByDocKeys(request.resource.data));

      allow read: if isAdmin() ||
        (isSignedIn() && (
          ("userId" in resource.data && resource.data.userId == request.auth.uid) ||
          ("contact" in resource.data && "emailLower" in resource.data.contact &&
           resource.data.contact.emailLower == userEmailLower())
        )) ||
        (isSignedIn() && canAccessByDocKeys(resource.data));

      allow update, delete: if isAdmin() ||
        (isSignedIn() && ("userId" in resource.data) && resource.data.userId == request.auth.uid) ||
        (isSignedIn() && canAccessByDocKeys(resource.data));
    }

    /* ---------- Services ---------- */
    match /services/{slug} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /* ---------- Mail enqueue ---------- */
    match /mail/{id} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }

    /* ---------- Reports ---------- */
    match /reports/{id} {
      allow read, write: if isAdmin() ||
        (isSignedIn() && canAccessByDocKeys(resource.data));
    }

    /* ---------- Users & subcollection addresses ---------- */
    match /users/{uid} {
      allow read, update: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      match /addresses/{addrId} {
        allow create: if isSignedIn() && request.auth.uid == uid;
        allow read, update, delete: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      }
    }

    /* ---------- Reviews ---------- */
    match /reviews/{id} {
      // Anyone can read approved reviews (for the public site).
      allow read: if resource.data.status == "approved" || isAdmin();

      // Auth’d users can create their own review.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Only admins can moderate.
      allow update, delete: if isAdmin();
    }

    /* ---------- Availability ---------- */
    match /availability/{dateKey} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /* ---------- Global admin override ---------- */
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
