rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmailLower() {
      return isSignedIn() && request.auth.token.email != null
        ? lower(request.auth.token.email)
        : "";
    }

    function adminDocActive(uid) {
      return exists(/databases/$(database)/documents/admins/$(uid)) &&
        get(/databases/$(database)/documents/admins/$(uid)).data.active == true;
    }

    function profileRoleAdminOrOwner(uid) {
      return exists(/databases/$(database)/documents/profiles/$(uid)) &&
        get(/databases/$(database)/documents/profiles/$(uid)).data.role in ["admin", "owner"];
    }

    function isAdmin() {
      return isSignedIn() &&
        (adminDocActive(request.auth.uid) || profileRoleAdminOrOwner(request.auth.uid));
    }

    function isOwnerUid(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isBookingOwner(docData) {
      return isSignedIn() && (
        (("userId" in docData) && docData.userId == request.auth.uid) ||
        (("ownerKeys" in docData) && docData.ownerKeys is list && (
          ("uid:" + request.auth.uid) in docData.ownerKeys ||
          ("email:" + userEmailLower()) in docData.ownerKeys
        )) ||
        (("contactEmailLower" in docData) && docData.contactEmailLower == userEmailLower()) ||
        (("contact" in docData) &&
          ("emailLower" in docData.contact) &&
          docData.contact.emailLower == userEmailLower())
      );
    }

    function ownsBookingId(bookingId) {
      return bookingId is string &&
        exists(/databases/$(database)/documents/bookings/$(bookingId)) &&
        isBookingOwner(get(/databases/$(database)/documents/bookings/$(bookingId)).data);
    }

    function safeProfileCreate(uid) {
      let d = request.resource.data;
      return isOwnerUid(uid) &&
        !d.keys().hasAny(["role", "admin", "isAdmin", "ltv", "lastBookingAt"]) &&
        (!("uid" in d) || d.uid == uid) &&
        (!("emailLower" in d) || d.emailLower == userEmailLower());
    }

    function safeProfileUpdate(uid) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isOwnerUid(uid) &&
        !changed.hasAny(["uid", "role", "admin", "isAdmin", "ltv", "lastBookingAt"]) &&
        (!("emailLower" in request.resource.data) ||
          request.resource.data.emailLower == userEmailLower());
    }

    function safeClientBookingUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let allowed = [
        "updatedAt", "notes", "cleanerNotes", "accessNotes",
        "reviewId", "reviewRating", "reviewLeftAt"
      ];
      let reviewIdOk =
        !changed.hasAny(["reviewId"]) ||
        (!("reviewId" in resource.data) &&
          request.resource.data.reviewId is string &&
          request.resource.data.reviewId.size() > 0);
      let reviewRatingOk =
        !changed.hasAny(["reviewRating"]) ||
        (!("reviewRating" in resource.data) &&
          request.resource.data.reviewRating is int &&
          request.resource.data.reviewRating >= 1 &&
          request.resource.data.reviewRating <= 5);
      let reviewLeftAtOk =
        !changed.hasAny(["reviewLeftAt"]) ||
        (!("reviewLeftAt" in resource.data) &&
          request.resource.data.reviewLeftAt is timestamp);

      return changed.hasOnly(allowed) &&
        reviewIdOk &&
        reviewRatingOk &&
        reviewLeftAtOk;
    }

    function validClientReviewCreate() {
      let d = request.resource.data;
      return isSignedIn() &&
        d.keys().hasOnly([
          "clientId", "bookingId", "serviceName", "displayMode",
          "reviewDisplayName", "rating", "comment", "body",
          "source", "status", "createdAt"
        ]) &&
        d.clientId == request.auth.uid &&
        ownsBookingId(d.bookingId) &&
        d.status == "pending" &&
        d.source == "client-portal" &&
        d.displayMode in ["anonymous", "initials", "firstInitialLastName"] &&
        d.reviewDisplayName is string &&
        d.rating is int &&
        d.rating >= 1 &&
        d.rating <= 5 &&
        d.comment is string &&
        d.comment.size() >= 5 &&
        d.comment.size() <= 2000 &&
        d.body == d.comment &&
        d.createdAt is timestamp;
    }

    match /admins/{uid} {
      allow read: if isAdmin() || isOwnerUid(uid);
      allow create, update, delete: if isAdmin();
    }

    match /profiles/{uid} {
      allow read: if isAdmin() || isOwnerUid(uid);
      allow create: if isAdmin() || safeProfileCreate(uid);
      allow update: if isAdmin() || safeProfileUpdate(uid);
      allow delete: if isAdmin();

      match /addresses/{addressId} {
        allow read, create, update, delete: if isAdmin() || isOwnerUid(uid);
      }
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() || isBookingOwner(resource.data);
      allow create, delete: if false;
      allow update: if isAdmin() ||
        (isBookingOwner(resource.data) && safeClientBookingUpdate());
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() ||
        (isSignedIn() && (
          (("userId" in resource.data) && resource.data.userId == request.auth.uid) ||
          (("bookingId" in resource.data) && ownsBookingId(resource.data.bookingId))
        ));
      allow create, update, delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if isAdmin() ||
        (resource.data.status == "approved") ||
        (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow create: if validClientReviewCreate();
      allow update, delete: if isAdmin();
    }

    match /services/{slug} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }

    match /reports/{reportId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /availability/{dateKey} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /blackouts/{blackoutId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /bookingReservations/{dateKey} {
      allow read, create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
